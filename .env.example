# Required
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...
DATABASE_URL=postgresql://taxcite:taxcite@localhost:5432/taxcite

# Optional
ANTHROPIC_MODEL=claude-sonnet-4-6   # override with claude-opus-4-8 for higher accuracy
OPENAI_API_KEY=sk-...               # used by Ragas judge LLM during eval

# LangSmith tracing (optional but highly recommended for observability)
LANGCHAIN_API_KEY=lsv2_pt_...       # get from smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=taxcite
